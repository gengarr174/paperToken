<%- include("includes/header") %>
<%- include("includes/navbar") %>
</head>
<body>
<main>
  <div class="page-title">Painel Administrativo</div>
  <div class="page-sub">Gerencie os usuários cadastrados no sistema.</div>

  <%- include('includes/messages') %>

  <div class="stat-grid">
    <div class="stat-card">
      <div class="sc-label">Total de Usuários</div>
      <div class="sc-value text-primary">
        <%= users.filter(u => u.role !== 'admin').length %>
      </div>
    </div>
    <div class="stat-card">
      <div class="sc-label">Ativos</div>
      <div class="sc-value" style="color:var(--success)">
        <%= users.filter(u => u.role !== 'admin' && u.status === 'active').length %>
      </div>
    </div>
    <div class="stat-card">
      <div class="sc-label">Banidos</div>
      <div class="sc-value" style="color:var(--danger)">
        <%= users.filter(u => u.role !== 'admin' && u.status === 'banned').length %>
      </div>
    </div>
  </div>

  <div class="table-card">
    <div class="tbl-toolbar">
      <div class="search-wrap">
        <i class="bi bi-search"></i>
        <input type="text" id="search" placeholder="Buscar por nome ou e-mail…" oninput="filterTableAdmin()"/>
      </div>
      <select class="form-select form-select-sm" style="width:140px" id="f-status" onchange="filterTableAdmin()">
        <option value="">Todos os status</option>
        <option value="active">Ativos</option>
        <option value="banned">Banidos</option>
      </select>
    </div>

    <div style="overflow-x:auto">
      <table>
        <thead>
          <tr>
            <th>Usuário</th>
            <th class="hm">Função</th>
            <th class="hm">Status</th>
            <th class="hm">Moedas</th>
            <th style="text-align:right">Ações</th>
          </tr>
        </thead>
        <tbody id="tbody">
          <% users.filter(u => u.role !== 'admin').forEach(u => { %>
          <tr data-name="<%= (u.name+' '+u.last_name).toLowerCase() %>"
              data-email="<%= u.email.toLowerCase() %>"
              data-status="<%= u.status %>">
            <td>
              <div class="user-cell">
                <div class="user-avatar"><%= u.name.charAt(0).toUpperCase() %></div>
                <div>
                  <div class="user-name"><%= u.name %> <%= u.last_name %></div>
                  <div class="user-email"><%= u.email %></div>
                </div>
              </div>
            </td>
            <td class="hm">
              <span class="badge bg-secondary"><%= u.role %></span>
            </td>
            <td class="hm">
              <% if(u.status === 'active') { %>
                <span class="badge" style="background:#ebfbee;color:var(--success)">Ativo</span>
              <% } else { %>
                <span class="badge" style="background:#fff5f5;color:var(--danger)">Banido</span>
              <% } %>
            </td>
            <td class="hm" style="font-size:.84rem;color:var(--muted)"><%= u.tokens %></td>
            <td>
              <div class="d-flex gap-1 justify-content-end">
                <% if(u.status === 'active') { %>
                  <button class="tbl-btn ban" title="Banir"
                    onclick='openEditAdmin(<%= u.id %>, <%- JSON.stringify(u.name) %>, "banned")'>
                    <i class="bi bi-slash-circle"></i>
                  </button>
                <% } else { %>
                  <button class="tbl-btn unban" title="Desbanir"
                    onclick='openEditAdmin(<%= u.id %>, <%- JSON.stringify(u.name) %>, "active")'>
                    <i class="bi bi-check-circle"></i>
                  </button>
                <% } %>
                <button class="tbl-btn del" title="Excluir"
                  onclick='openDelAdmin(<%= u.id %>, <%- JSON.stringify(u.name + " " + u.last_name) %>)'>
                  <i class="bi bi-trash3"></i>
                </button>
              </div>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>

    <% if(!users || users.filter(u => u.role !== 'admin').length === 0) { %>
    <div class="empty-wrap">
      <i class="bi bi-people d-block"></i>
      <p>Nenhum usuário encontrado.</p>
    </div>
    <% } %>

    <div class="tbl-footer">
      <div id="pg-info"><%= users.filter(u => u.role !== 'admin').length %> usuário(s)</div>
    </div>
  </div>
</main>

<div class="t-stack" id="tstack"></div>

<%- include('includes/modal/profile') %>
<%- include('includes/modal/edit') %>
<%- include('includes/modal/delete') %>
<%- include('includes/modal/logout') %>
<%- include('includes/modal/password') %>

<script src="/js/home_admin.js"></script>

<%-include("includes/footer") %>